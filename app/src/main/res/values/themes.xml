<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Ruyani" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_dark</item>
        <item name="colorOnPrimaryContainer">@color/primary_light</item>

        <!-- Secondary colors (reuse primary for cohesive look) -->
        <item name="colorSecondary">@color/primary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/surface_variant</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>

        <!-- Tertiary colors -->
        <item name="colorTertiary">@color/primary_light</item>
        <item name="colorOnTertiary">@color/black</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Outline -->
        <item name="colorOutline">@color/divider</item>

        <!-- Error -->
        <item name="colorError">@color/status_inactive</item>
        <item name="colorOnError">@color/white</item>

        <!-- Window backgrounds -->
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>

        <!-- Light status-bar icons (false = white icons for dark bg) -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

</resources>
